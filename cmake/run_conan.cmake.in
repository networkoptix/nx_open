#!/usr/bin/env -S cmake -P

## Copyright 2018-present Network Optix, Inc. Licensed under MPL 2.0: www.mozilla.org/MPL/2.0/

cmake_minimum_required(VERSION 3.20)

include(CMakeParseArguments)

set(ENV{CONAN_HOME} "@CONAN_HOME@")
set(CONAN_EXECUTABLE "@CONAN_EXECUTABLE@")
set(CMAKE_SOURCE_DIR "@CMAKE_SOURCE_DIR@")
set(CMAKE_BINARY_DIR "@CMAKE_BINARY_DIR@")

set(installSystemRequirements "OFF" CACHE INTERNAL "")

set(conanNxRemote "@conanNxRemote@")
set(conanFlags @flags@)

if(installSystemRequirements)
    set(conanFlags
        ${conanFlags}
         "-c tools.system.package_manager:mode=install"
         "-c tools.system.package_manager:sudo=True")
    set(ENV{CONAN_SYSREQUIRES_SUDO} "True")
    set(ENV{CONAN_SYSREQUIRES_MODE} "enabled")
else()
    set(conanFlags
        ${conanFlags}
         "-c tools.system.package_manager:mode=check"
         "-c tools.system.package_manager:sudo=False")
    set(ENV{CONAN_SYSREQUIRES_SUDO} "False")
    set(ENV{CONAN_SYSREQUIRES_MODE} "verify")
endif()

# TODO VMS-39555: NX_CONAN_USERNAME/NX_CONAN_PASSWORD are a temporary workaround for the
# open-source build where the conan remote (us.nxteam.dev) differs from the general Artifactory
# (nxvms.dev). Once a dedicated conan2-open repo is set up on nxvms.dev, both remotes will be on
# the same server and NX_ARTIFACTORY_USERNAME/PASSWORD can be used for both again.
# NX_CONAN_USERNAME/NX_CONAN_PASSWORD take precedence over NX_ARTIFACTORY_USERNAME/PASSWORD.
if(DEFINED ENV{NX_CONAN_USERNAME} AND DEFINED ENV{NX_CONAN_PASSWORD})
    set(conan_username "$ENV{NX_CONAN_USERNAME}")
    set(conan_password "$ENV{NX_CONAN_PASSWORD}")
elseif(DEFINED ENV{NX_ARTIFACTORY_USERNAME} AND DEFINED ENV{NX_ARTIFACTORY_PASSWORD})
    set(conan_username "$ENV{NX_ARTIFACTORY_USERNAME}")
    set(conan_password "$ENV{NX_ARTIFACTORY_PASSWORD}")
endif()

if(DEFINED conan_username)
    message(STATUS "Authenticating with Conan remote as ${conan_username}...")
    execute_process(
        COMMAND ${CONAN_EXECUTABLE} remote login nx
            ${conan_username} -p ${conan_password}
        RESULT_VARIABLE login_result
    )
    if(NOT login_result EQUAL 0)
        message(WARNING "Conan remote login failed with code ${login_result}")
    endif()
endif()

function(run_conan)
    execute_process(
        COMMAND
            ${CONAN_EXECUTABLE} install ${CMAKE_SOURCE_DIR}
            ${conanFlags}
            --output-folder ${CMAKE_BINARY_DIR}
            -vv
            ${ARGV}
        COMMAND_ECHO STDERR
        RESULT_VARIABLE result
    )

    if(result EQUAL 0)
        set(CONAN_FAILED FALSE PARENT_SCOPE)
    else()
        set(CONAN_FAILED TRUE PARENT_SCOPE)
    endif()
endfunction()

run_conan()

if(CONAN_FAILED)
    message(FATAL_ERROR "Conan failed to install dependencies.")
endif()
